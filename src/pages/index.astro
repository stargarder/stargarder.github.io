---
// import Sticker from "../components/Sticker.astro";
import "swiper/css";
import "swiper/css/navigation";
import "swiper/css/pagination";

const gallerySlides = [
  {
    src: "/gallery/1.webp",
    en: "Neighbours, tenants and supporters gathering in front of the building before the demo.",
    de: "Nachbar:innen, Mieter:innen und Unterstützer:innen versammeln sich vor dem Gebäude vor der Demo.",
  },
  {
    src: "/gallery/2.webp",
    en: "Signs with our demands and unanswered questions before the demo.",
    de: "Schilder mit unseren Forderungen und unbeantworteten Fragen vor der Demo.",
  },
  {
    src: "/gallery/3.webp",
    en: "Housing is a human right!",
    de: "Wohnen is ein Grundrecht",
  },
  {
    src: "/gallery/4.webp",
    en: "Shorterm contracts is one of the issues of our house, the neighbourhood and the city.",
    de: "Befristete Verträge sind eines der Probleme unseres Hauses, der Nachbarschaft und der Stadt.",
  },
  {
    src: "/gallery/5.webp",
    en: "People showing their solidarity with the affected tenants and neighbours and discussing the issues.",
    de: "Menschen zeigen ihre Solidarität mit den betroffenen Mieter:innen und Nachbar:innen und diskutieren die Probleme.",
  },
  {
    src: "/gallery/6.webp",
    en: "Artist Marina Resende Santos created a performative installation using smoke-damaged potatoes from the basement, repurposing them to generate electricity for the house.",
    de: "Künstlerin Marina Resende Santos hat eine performative Installation mit rauchgeschädigten Kartoffeln aus dem Keller geschaffen, die zur Stromerzeugung für das Haus wiederverwendet wurden.",
  },
  {
    src: "/gallery/7.webp",
    en: "Tenants showing their stories with the public",
    de: "Die Mieter:innen teilen ihre Geschichten mit der Öffentlichkeit",
  },
  {
    src: "/gallery/8.webp",
    en: "The media is interested in our story and the issues we are facing.",
    de: "Das Medieninteresse an unserer Geschichte und den Problemen, mit denen wir konfrontiert sind.",
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script data-goatcounter="https://stargarder.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
    <title>Stargarder gegen Verdrängung</title>
  </head>
  <body>
    <!-- <div class="stickers">
      <Sticker content="👾" />
      <Sticker content="⚡" />
      <Sticker content="⛈" />
      <Sticker content="🤡" />
      <Sticker content="👹" />
      <Sticker content="👻" />
    </div> -->
    <div class="lang-switch" role="group" aria-label="Language switch">
      <button type="button" data-set-lang="de">DE</button>
      <button type="button" data-set-lang="en">EN</button>
    </div>
    <h1 data-lang="en">Demo (Past Event)</h1>
    <h1 data-lang="de">Demo (Vergangenes Event)</h1>
    <section class="gallery-section" aria-label="Demo gallery">
      <div class="swiper" aria-live="polite">
        <div class="swiper-wrapper">
          {
            gallerySlides.map((slide, index) => (
              <figure class="swiper-slide">
                <img src={slide.src} alt={slide.en} loading={index === 0 ? "eager" : "lazy"} />
                <figcaption>
                  <span data-lang="en">{slide.en}</span>
                  <span data-lang="de">{slide.de}</span>
                </figcaption>
              </figure>
            ))
          }
        </div>
        <div class="gallery-controls">
          <button class="swiper-button-prev" aria-label="Previous slide"></button>
          <div class="swiper-pagination"></div>
          <button class="swiper-button-next" aria-label="Next slide"></button>
        </div>
      </div>
    </section>
    <h2>Stargarder gegen Verdrängung</h2>
    <h1 data-lang="de">Kommt! Macht mit! Solidarität!</h1>
    <h1 data-lang="en">Come! Join! Solidarity!</h1>
    <p class="location" data-lang="de">Freitag, 6. März um 18:00, bei der <a
        href="https://maps.app.goo.gl/RFj5iowZPQy1icsN6"
        target="_blank">Gethsemane-Kirche</a
      >
    </p>
    <p class="location" data-lang="en">Friday, March 6 at 18:00, at <a
        href="https://maps.app.goo.gl/RFj5iowZPQy1icsN6"
        target="_blank">Gethsemane Church</a
      >
    </p>
    <img
      src="/map.svg"
      class="image"
      alt="Demo Flyer"
      style="max-width: 500px; height: auto"
    />
    <h3 data-lang="de">Programm</h3>
    <h3 data-lang="en">Program</h3>
    <div class="timetable">
      <div>18:00</div><div>
        <span data-lang="de"
          >Start der Demonstration (vor der Stargarder Str. 76 /
          Gethsemane-Kirche)</span
        >
        <span data-lang="en"
          >Start of the demonstration (in front of Stargarder Str. 76 /
          Gethsemane Church)</span
        >
      </div>
      <div>18:30</div>
      <div>
        <div data-lang="de">Redebeiträge</div>
        <div data-lang="en">Speeches and contributions</div>
        <ul data-lang="de">
          <li>betroffene Mieter:innen und Nachbar:innen</li>
          <li>
            Maria Bigos, Fraktionsvorsitzende der Linksfraktion BVV Pankow
          </li>
          <li>
            Linda Vierecke, Mitglied des Abgeordnetenhauses von Berlin,
            SPD-Fraktion
          </li>
          <li>
            Julia Schneider MdB, für Pankow im Bundestag, Bündnis 90/Die Grünen
          </li>
          <li>Initiative Pankow gegen Verdrängung</li>
        </ul>
        <ul data-lang="en">
          <li>affected tenants and neighbours</li>
          <li>
            Maria Bigos, parliamentary group chair of The Left in Pankow
            district council
          </li>
          <li>
            Linda Vierecke, Member of the Berlin House of Representatives, SPD
            parliamentary group
          </li>
          <li>
            Julia Schneider, Member of Parliament for Pankow, Bündnis 90/Die
            Grünen
          </li>
          <li>Initiative Pankow gegen Verdrängung</li>
        </ul>
      </div>
      <div>20:00</div><div>
        <span data-lang="de"
          >Nachbarschaftstreffen für alle im Hof unseres Hauses mit Suppe und
          performativer Installation der Künstlerin Marina Resende Santos</span
        >
        <span data-lang="en"
          >Neighbourhood meeting for everyone in the yard of our home with soup
          and a performative installation by artist Marina Resende Santos</span
        >
      </div>
      <div>21:00</div>
      <div>
        <span data-lang="de">Ende</span>
        <span data-lang="en">End</span>
      </div>
    </div>
    <h3 data-lang="de">
      Seit Januar befinden wir uns in einer schwierigen Lage!
    </h3>
    <p data-lang="de">
      Ein Haus mit 40 Familien wurde über Nacht ohne Angebot einer
      Ersatzunterkunft geräumt. Das ist nun schon seit über einem Monat so. Die
      Reparaturarbeiten ziehen sich endlos hin und führen zu einer
      Gentrifizierung. Viele NachbarInnen haben schon auf ihre Wohnungen
      verzichtet.
    </p>
    <p data-lang="de">
      Lasst uns gemeinsam die unmenschliche Politik der Vermieter stoppen!
      Landlord sind keine MenschenLord! Die Stadt ist für Menschen da, nicht für
      möblierte Luxuswohnungen!
    </p>
    <h3 data-lang="de">Unsere Forderungen:</h3>
    <ul data-lang="de">
      <li>Wir brauchen Wasser! (sofort!)</li>
      <li>Wir brauchen Strom! (mindestens Baulicht für alle Gebäude!)</li>
      <li>Wir brauchen Heizung!</li>
      <li>
        Wir fordern einen verbindlichen und transparenten Zeitplan für die
        Reparaturarbeiten.
      </li>
    </ul>
    <h3 data-lang="en">Since January we are in a difficult situation!</h3>
    <p data-lang="en">
      40 families were forced to leave their homes and to live in the street
      overnight and have been unable to return for 6 weeks. Some of us left
      Berlin, others live separated from their families. Repair work is becoming
      endless and turning into gentrification. Some neighbors have already given
      up their apartments.
    </p>
    <p data-lang="en">
      Let's stop the problematic policies of landlords together! Landlords are
      not humanlords! The city is for people, not furnished luxury apartments!
    </p>
    <h3 data-lang="en">Our demands</h3>
    <ul data-lang="en">
      <li>We need water! (asap)</li>
      <li>We need light! (at least construction light for all buildings)</li>
      <li>To restore gas supply (asap)!</li>
      <li>
        We demand a binding and transparent timetable for the repair works.
      </li>
    </ul>
        <h3 data-lang="de">Medienberichterstattung</h3>
    <h3 data-lang="en">Media Coverage</h3>
    <div class="media-coverage">
      <a
        href="https://www.rbb-online.de/der-tag/ort/Vor-Ort-in-der-Stargarder-Strasse.html"
        target="_blank"      >
        RBB
      </a>
      <span class="date">6.3.2026</span>
      <a
        href="https://www.morgenpost.de/bezirke/pankow/article411394290/mieter-demonstrieren-gegen-leerstand-nach-kellerbrand-in-prenzlauer-berg.html"
        target="_blank"      >
        Morgenpost
      </a>
      <span class="date">6.3.2026</span>
      <a
        href="https://www.tagesspiegel.de/berlin/bezirke/pankow/akutes-beispiel-fur-verdrangungsstrategien-kehren-die-mieter-nie-wieder-in-das-berliner-kellerbrand-haus-zuruck-15319221.html"
        target="_blank"      >
        Tagesspiegel
      </a>
      <span class="date">5.3.2026</span>
      <a
        href="https://taz.de/Kellerbrand-in-der-Stargarder-Strasse/!6157145/"
        target="_blank">TAZ</a
      >
      <span class="date">27.2.2026</span>
      <a
        href="https://www.morgenpost.de/bezirke/pankow/article411262470/bittere-botschaften-nach-brand-120-menschen-ihrer-haeuser-beraubt.html"
        target="_blank">Morgenpost</a
      >
      <span class="date">21.2.2026</span>
      <a
        href="https://www.berliner-zeitung.de/mensch-metropole/unfaehigkeit-oder-entmietung-der-kellerbrand-in-der-stargarder-strasse-li.10019128"
        target="_blank">Berliner Zeitung</a
      >
      <span class="date">15.2.2026</span>
      <a
        href="https://www.loky.news/loky-sprengung-jahn-sportpark/#:~:text=was%20tun%2C%20wenn's%20brennt%3F"
        target="_blank"
      >
        Loky News
      </a>
      <span class="date">13.2.2026</span>
      <a
        href="https://www.tagesspiegel.de/berlin/bezirke/pankow/ein-kellerbrand-mit-verheerenden-folgen-40-familien-in-berlin-sind-seit-wochen-wohnungslos--ein-ende-ist-nicht-in-sicht-15236237.html"
        target="_blank"
      >
        Tagesspiegel
      </a>
      <span class="date">12.2.2026</span>
    </div>
    <script is:inline>
      const STORAGE_KEY = "stargarder-language";
      const html = document.documentElement;
      const buttons = document.querySelectorAll("[data-set-lang]");

      const setLanguage = (lang) => {
        html.lang = lang;
        localStorage.setItem(STORAGE_KEY, lang);
        document.querySelectorAll("[data-lang]").forEach((element) => {
          element.hidden = element.dataset.lang !== lang;
        });
        buttons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.setLang === lang);
        });
      };

      const savedLanguage = localStorage.getItem(STORAGE_KEY);
      const browserLanguage = navigator.language?.toLowerCase().startsWith("de")
        ? "de"
        : "en";
      const initialLanguage =
        savedLanguage === "de" || savedLanguage === "en"
          ? savedLanguage
          : browserLanguage;

      setLanguage(initialLanguage);

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const lang = button.dataset.setLang;
          if (lang === "de" || lang === "en") {
            setLanguage(lang);
          }
        });
      });
    </script>
    <script>
      import Swiper from "swiper";
      import { Navigation, Pagination, A11y, Autoplay } from "swiper/modules";

      const gallery = document.querySelector(".swiper");

      if (gallery) {
        new Swiper(gallery, {
          modules: [Navigation, Pagination, A11y, Autoplay],
          loop: true,
          spaceBetween: 20,
          slidesPerView: 1,
          autoplay: {
            delay: 3500,
            disableOnInteraction: true,
            pauseOnMouseEnter: true,
          },
          pagination: {
            el: ".swiper-pagination",
            clickable: true,
          },
          navigation: {
            addIcons: false,
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
          },
        });
      }
    </script>
  </body>
</html>

<style lang="scss">
  @font-face {
    font-family: "Stefan Bubble";
    src: url("/ABCStefan-Bubble.subset.woff2") format("woff2");
  }
  @font-face {
    font-family: "Stefan Simple";
    src: url("/ABCStefan-Simple.subset.woff2") format("woff2");
  }
  @font-face {
    font-family: "Gravity";
    src: url("/ABCGravityVariable.subset.woff2") format("woff2");
  }
  .image {
    width: 100%;
  }
  .stickers {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    left: 0;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
  }
  .date {
    font-family: "Stefan Simple";
    color: inherit;
  }
  .lang-switch {
    display: inline-flex;
    gap: 0.5rem;
  }
  .lang-switch button {
    font-family: "Stefan Simple";
    border: 4px solid black;
    background: transparent;
    color: black;
    cursor: pointer;
    padding: 0.2rem 1ch;
    font-size: 2rem;
    border-radius: 999px;
  }
  .lang-switch button.is-active {
    background: black;
    color: white;
  }
  a,
  a:visited {
    font-family: "Stefan Simple";
    color: blue;
    text-decoration: none;
  }
  html,
  body {
    overscroll-behavior: none;
  }
  body {
    padding-top: 50px;
    padding-bottom: 50px;
    padding-left: 25px;
    padding-right: 25px;
    @media (max-width: 800px) {
      padding-top: 20px;
      padding-bottom: 50px;
      padding-left: 10px;
      padding-right: 10px;
    }
    font-family: "Stefan Simple";
    font-size: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #17ffc5;
    color: black;
  }
  p {
    max-width: 600px;
  }
  * {
    margin: 0;
  }
  h1,
  h3 {
    font-family:
      "Gravity", Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
    font-variation-settings:
      "wght" 1000,
      "wdth" 70;
    // text-transform: uppercase;
    // white-space: pre-line;
    letter-spacing: -0.01em;
    font-size: 5vw;
    line-height: 0.8em;
    text-align: center;
    font-weight: 400;
    @media (max-width: 800px) {
      font-size: 10vw;
    }
  }
  h2,
  .location {
    font-family: "Stefan Simple";
    text-transform: uppercase;
    letter-spacing: -0.01em;
    white-space: pre-line;
    text-align: center;
    font-weight: 400;
  }
  .timetable {
    max-width: 40ch;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5em 4ch;
    @media (max-width: 800px) {
      gap: 0.5em 1ch;
    }
    font-family: "Stefan Simple";
    ul {
      padding: 1ch;
    }
  }
  .media-coverage {
    font-family: "Gravity", sans-serif;
    display: grid;
    gap: 0 4ch;
    @media (max-width: 800px) {
      gap: 0 2ch;
    }
    grid-template-columns: auto auto;
    text-align: center;
    list-style: none;
    a::before {
      content: "→";
      font-family: "Stefan Simple";
      margin-right: 0.5ch;
    }
    a::after {
      content: "←";
      font-family: "Stefan Simple";
      margin-left: 0.5ch;
      text-decoration: none !important;
    }
  }
  .gallery-section {
    width: min(600px, 100%);
  }
  .gallery-section h3 {
    margin-bottom: 20px;
  }
  .swiper {
    width: 100%;
    padding: 16px;
    box-sizing: border-box;
  }
  .swiper-slide {
    margin: 0;
  }
  .swiper-slide img {
    // width: 100%;
    margin: 0 auto;
    // width: min(260px, 70vh);
    width: 100%;
    height: 70vh;
    display: block;
    object-fit: cover;
  }
  .swiper-slide figcaption {
    margin-top: 12px;
    text-align: left;
    font-size: 1rem;
    line-height: 1.35;
  }
  .gallery-controls {
    // margin-top: 14px;
    display: grid;
    grid-template-columns: 44px 1fr 44px;
    align-items: center;
    gap: 10px;
  }
  :global(.swiper-button-prev),
  :global(.swiper-button-next) {
    position: static;
    margin: 0;
    width: auto;
    height: auto;
    color: black;
    background: transparent;
    border: none;
    outline: none;
    font-family: "Stefan Simple";
    font-size: 2.2rem;
    line-height: 1;
    justify-self: center;
    margin-top: 0px !important;
  }
  :global(.swiper-button-prev::after),
  :global(.swiper-button-next::after) {
    font-size: inherit;
    font-family: inherit;
  }
  :global(.swiper-navigation-icon) {
    display: none !important;
  }
  :global(.swiper-button-prev::after) {
    content: "\2190";
  }
  :global(.swiper-button-next::after) {
    content: "\2192";
  }
  :global(.swiper-pagination) {
    position: static;
    justify-self: center;
    text-align: center;
  }
  :global(.swiper-pagination-bullet) {
    background: black;
    opacity: 0.3;
  }
  :global(.swiper-pagination-bullet-active) {
    opacity: 1;
  }
  body > * + * {
    margin-top: 50px;
  }
</style>
